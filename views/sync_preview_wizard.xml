<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_sync_syscom_preview_wizard" model="ir.ui.view">
            <field name="name">sync.syscom.preview.wizard.form</field>
            <field name="model">sync.syscom.preview.wizard</field>
            <field name="arch" type="xml">
                <form string="Previsualización de sincronización">
                    <sheet>
                        <group>
                            <field name="total_candidates" readonly="1"/>
                            <field name="total_selected" readonly="1"/>
                        </group>
                        <footer>
                            <button string="Volver a cargar" type="object" name="action_reload_candidates" class="btn-secondary"/>
                            <button string="Sincronizar" type="object" name="action_sync_confirm" class="btn-primary"/>
                            <button string="Cancelar" class="btn-secondary" special="cancel"/>
                        </footer>
                        <group string="Productos a sincronizar">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="selected"/>
                                    <field name="name"/>
                                    <field name="model"/>
                                    <field name="brand_name"/>
                                    <field name="price_list"/>
                                    <field name="price_list_mxn"/>
                                </tree>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_sync_syscom_preview" model="ir.actions.act_window">
            <field name="name">Previsualizar Sync</field>
            <field name="res_model">sync.syscom.preview.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{}</field>
        </record>
    </data>
</odoo>
