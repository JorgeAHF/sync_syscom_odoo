<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_sync_syscom" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.sync_syscom</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <div class="app_settings_block" data-string="SyncSyscom" string="SyncSyscom" groups="sync_syscom.group_sync_syscom_manager">
                        <h2>SyncSyscom</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="syscom_api_token"/>
                                    <div class="text-muted">
                                        Configura las credenciales para conectar con SYSCOM.
                                    </div>
                                    <div class="content-group mt16">
                                        <div class="row">
                                            <label class="col-lg-4 o_light_label" for="syscom_api_token"/>
                                            <div class="col-lg-8">
                                                <field name="syscom_api_token" widget="password"/>
                                            </div>
                                        </div>
                                        <div class="row mt8">
                                            <label class="col-lg-4 o_light_label" for="syscom_base_url"/>
                                            <div class="col-lg-8">
                                                <field name="syscom_base_url"/>
                                            </div>
                                        </div>
                                        <div class="row mt8">
                                            <label class="col-lg-4 o_light_label" for="syscom_timeout"/>
                                            <div class="col-lg-8">
                                                <field name="syscom_timeout"/>
                                            </div>
                                        </div>
                                        <div class="row mt8">
                                            <label class="col-lg-4 o_light_label" for="syscom_price_currency"/>
                                            <div class="col-lg-8">
                                                <field name="syscom_price_currency" class="oe_inline"/>
                                            </div>
                                        </div>
                                        <div class="row mt8">
                                            <label class="col-lg-4 o_light_label" for="syscom_pricelist_list"/>
                                            <div class="col-lg-8">
                                                <field name="syscom_pricelist_list" options=\"{'no_create': True}\"/>
                                            </div>
                                        </div>
                                        <div class="row mt8">
                                            <label class="col-lg-4 o_light_label" for="syscom_pricelist_special"/>
                                            <div class="col-lg-8">
                                                <field name="syscom_pricelist_special" options=\"{'no_create': True}\"/>
                                            </div>
                                        </div>
                                        <div class="row mt8">
                                            <label class="col-lg-4 o_light_label" for="syscom_min_stock"/>
                                            <div class="col-lg-8">
                                                <field name="syscom_min_stock" class="oe_inline"/>
                                                <span class="text-muted ms-2">Cantidad mínima en SYSCOM para publicar productos (>=1).</span>
                                            </div>
                                        </div>
                                        <div class="row mt16">
                                            <div class="col-lg-8 offset-lg-4">
                                                <button type="object" name="action_syscom_test_connection" string="Probar conexión" class="btn btn-primary"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
