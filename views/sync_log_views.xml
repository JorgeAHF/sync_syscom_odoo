<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_sync_syscom_log_tree" model="ir.ui.view">
            <field name="name">sync.syscom.log.list</field>
            <field name="model">sync.syscom.log</field>
            <field name="arch" type="xml">
                <list string="Logs SYSCOM">
                    <field name="create_date"/>
                    <field name="name"/>
                    <field name="kind"/>
                    <field name="message"/>
                </list>
            </field>
        </record>

        <record id="view_sync_syscom_log_form" model="ir.ui.view">
            <field name="name">sync.syscom.log.form</field>
            <field name="model">sync.syscom.log</field>
            <field name="arch" type="xml">
                <form string="Log SYSCOM">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="kind"/>
                            <field name="create_date"/>
                        </group>
                        <group>
                            <field name="message"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_sync_syscom_log" model="ir.actions.act_window">
            <field name="name">Logs SYSCOM</field>
            <field name="res_model">sync.syscom.log</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
