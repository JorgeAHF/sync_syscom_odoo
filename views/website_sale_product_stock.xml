<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="website_sale_product_syscom_stock" inherit_id="website_sale.product" name="SYSCOM Stock on PDP">
        <!--
          Show SYSCOM stock on product page (PDP).
          website_sale.product markup changes between minor versions / website themes,
          so we anchor on the first element in the template to avoid hard failures
          during module upgrade.
        -->
        <xpath expr="//*[1]" position="inside">
            <t t-if="product.syscom_is_product and product.syscom_product_id">
                <div class="mt-2 mb-2">
                    <div class="text-muted">
                        <strong>Stock SYSCOM (nuevo):</strong>
                        <span t-esc="product.syscom_stock_new"/>
                    </div>
                    <t t-if="product.syscom_stock_synced_at">
                        <div class="small text-muted">
                            Actualizado:
                            <span t-esc="product.syscom_stock_synced_at"/>
                        </div>
                    </t>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
