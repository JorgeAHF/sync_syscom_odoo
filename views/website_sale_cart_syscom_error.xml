<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="website_sale_cart_syscom_error" inherit_id="website_sale.cart" name="SYSCOM Cart Error">
        <!--
          website_sale.cart structure varies between versions/themes.
          Anchor on the first element in the template to prevent upgrade-time failures.
        -->
        <xpath expr="//*[1]" position="inside">
            <t t-set="syscom_error" t-value="request.session.get('syscom_error')"/>
            <t t-if="syscom_error">
                <div class="alert alert-danger" role="alert">
                    <t t-esc="syscom_error"/>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
