<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_sync_syscom_product_data_job_tree" model="ir.ui.view">
            <field name="name">sync.syscom.product.data.job.list</field>
            <field name="model">sync.syscom.product.data.job</field>
            <field name="arch" type="xml">
                <list string="Trabajos datos extendidos" create="false">
                    <field name="create_date"/>
                    <field name="name"/>
                    <field name="state"/>
                    <field name="processed_products"/>
                    <field name="total_products"/>
                    <field name="updated_products"/>
                    <field name="updated_templates"/>
                    <field name="remote_fetches"/>
                    <field name="last_error"/>
                </list>
            </field>
        </record>

        <record id="view_sync_syscom_product_data_job_form" model="ir.ui.view">
            <field name="name">sync.syscom.product.data.job.form</field>
            <field name="model">sync.syscom.product.data.job</field>
            <field name="arch" type="xml">
                <form string="Trabajo datos extendidos">
                    <sheet>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="state" readonly="1"/>
                            <field name="started_at" readonly="1"/>
                            <field name="finished_at" readonly="1"/>
                        </group>
                        <group string="Progreso">
                            <field name="product_offset" readonly="1"/>
                            <field name="processed_products" readonly="1"/>
                            <field name="total_products" readonly="1"/>
                            <field name="updated_products" readonly="1"/>
                            <field name="updated_templates" readonly="1"/>
                            <field name="remote_fetches" readonly="1"/>
                            <field name="skipped_products" readonly="1"/>
                        </group>
                        <group string="Errores">
                            <field name="last_error" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sync_syscom_product_data_job_search" model="ir.ui.view">
            <field name="name">sync.syscom.product.data.job.search</field>
            <field name="model">sync.syscom.product.data.job</field>
            <field name="arch" type="xml">
                <search string="Buscar trabajos datos extendidos">
                    <field name="name"/>
                    <filter name="pending" string="Pendientes" domain="[('state', '=', 'pending')]"/>
                    <filter name="running" string="Procesando" domain="[('state', '=', 'running')]"/>
                    <filter name="done" string="Terminados" domain="[('state', '=', 'done')]"/>
                    <filter name="error" string="Con error" domain="[('state', '=', 'error')]"/>
                </search>
            </field>
        </record>

        <record id="action_sync_syscom_product_data_job" model="ir.actions.act_window">
            <field name="name">Trabajos datos extendidos</field>
            <field name="res_model">sync.syscom.product.data.job</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
