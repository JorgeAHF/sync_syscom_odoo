<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Server actions must be declared before being referenced in views -->
        <record id="server_action_sync_syscom_brand" model="ir.actions.server">
            <field name="name">Sincronizar desde SYSCOM</field>
            <field name="model_id" ref="model_sync_syscom_brand"/>
            <field name="binding_model_id" ref="model_sync_syscom_brand"/>
            <field name="binding_type">action</field>
            <field name="state">code</field>
            <field name="code">
                action = env["sync.syscom.brand"].action_sync_syscom()
            </field>
        </record>

        <record id="server_action_sync_syscom_models_selected" model="ir.actions.server">
            <field name="name">Sincronizar modelos de marcas seleccionadas</field>
            <field name="model_id" ref="model_sync_syscom_brand"/>
            <field name="binding_model_id" ref="model_sync_syscom_brand"/>
            <field name="binding_type">action</field>
            <field name="state">code</field>
            <field name="code">
                action = env["sync.syscom.brand"].action_sync_models_selected()
            </field>
        </record>

        <record id="view_sync_syscom_brand_tree" model="ir.ui.view">
            <field name="name">sync.syscom.brand.list</field>
            <field name="model">sync.syscom.brand</field>
            <field name="arch" type="xml">
                <list string="Marcas SYSCOM">
                    <header>
                        <button
                            name="%(server_action_sync_syscom_models_selected)d"
                            type="action"
                            string="Sincronizar modelos de marcas seleccionadas"
                            class="btn-secondary"
                            groups="sync_syscom.group_sync_syscom_manager"
                        />
                        <button
                            name="%(server_action_sync_syscom_brand)d"
                            type="action"
                            string="Sincronizar desde SYSCOM"
                            class="btn-primary"
                            groups="sync_syscom.group_sync_syscom_manager"
                        />
                    </header>
                    <field name="selected"/>
                    <field name="name"/>
                    <field name="syscom_id"/>
                    <field name="title"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_sync_syscom_brand_form" model="ir.ui.view">
            <field name="name">sync.syscom.brand.form</field>
            <field name="model">sync.syscom.brand</field>
            <field name="arch" type="xml">
                <form string="Marca SYSCOM">
                    <header>
                        <button name="action_sync_all_models" type="object" string="Sincronizar todos los modelos" class="btn-secondary" groups="sync_syscom.group_sync_syscom_manager"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="syscom_id"/>
                            <field name="title"/>
                            <field name="logo_url"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                        <notebook>
                            <page string="Categorías">
                                <field name="category_ids" widget="many2many_tags"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_sync_syscom_brand" model="ir.actions.act_window">
            <field name="name">Marcas SYSCOM</field>
            <field name="res_model">sync.syscom.brand</field>
            <field name="view_id" ref="view_sync_syscom_brand_tree"/>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Sincroniza marcas desde SYSCOM.</p>
            </field>
        </record>
    </data>
</odoo>
