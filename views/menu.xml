<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="server_action_sync_cat_brand_models" model="ir.actions.server">
            <field name="name">Sincronizar categorías, marcas y modelos</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="binding_model_id" ref="base.model_res_users"/>
            <field name="binding_type">action</field>
            <field name="state">code</field>
            <field name="code">
params = env["ir.config_parameter"].sudo()
params.set_param("sync_syscom.category_sync_offset", 0)
params.set_param("sync_syscom.brand_sync_offset", 0)
params.set_param("sync_syscom.brand_products_sync_offset", 0)

# Desactivar crons para reinicio limpio
cron_cat = env.ref("sync_syscom.cron_sync_syscom_categories", raise_if_not_found=False)
cron_brand = env.ref("sync_syscom.cron_sync_syscom_brands_full", raise_if_not_found=False)
cron_prod = env.ref("sync_syscom.cron_sync_syscom_brand_products", raise_if_not_found=False)
for cron in (cron_cat, cron_brand, cron_prod):
    if cron:
        cron.active = False

# Activar pipeline: categorías -> marcas -> productos
if cron_cat:
    cron_cat.active = True
            </field>
        </record>

        <menuitem id="menu_sync_syscom_root" name="SyncSyscom" groups="sync_syscom.group_sync_syscom_manager"/>
        <menuitem
            id="menu_sync_syscom_sync"
            name="Sincronizar"
            parent="menu_sync_syscom_root"
            groups="sync_syscom.group_sync_syscom_manager"
        />
        <menuitem
            id="menu_sync_syscom_catalogs"
            name="Catálogos"
            parent="menu_sync_syscom_root"
            groups="sync_syscom.group_sync_syscom_manager"
        />
        <menuitem
            id="menu_sync_syscom_sync_all"
            name="Categorías/Marcas/Modelos"
            parent="menu_sync_syscom_sync"
            action="server_action_sync_cat_brand_models"
            groups="sync_syscom.group_sync_syscom_manager"
        />
        <menuitem
            id="menu_sync_syscom_categories"
            name="Categorías"
            parent="menu_sync_syscom_catalogs"
            action="action_sync_syscom_category"
            groups="sync_syscom.group_sync_syscom_manager"
        />
        <menuitem
            id="menu_sync_syscom_brands"
            name="Marcas"
            parent="menu_sync_syscom_catalogs"
            action="action_sync_syscom_brand"
            groups="sync_syscom.group_sync_syscom_manager"
        />
        <menuitem
            id="menu_sync_syscom_products"
            name="Modelos"
            parent="menu_sync_syscom_catalogs"
            action="action_sync_syscom_product"
            groups="sync_syscom.group_sync_syscom_manager"
        />
        <menuitem
            id="menu_sync_syscom_logs"
            name="Logs"
            parent="menu_sync_syscom_root"
            action="action_sync_syscom_log"
            groups="sync_syscom.group_sync_syscom_manager"
        />
    </data>
</odoo>
