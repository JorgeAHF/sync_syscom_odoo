<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_sync_syscom_cost_job_tree" model="ir.ui.view">
            <field name="name">sync.syscom.cost.job.list</field>
            <field name="model">sync.syscom.cost.job</field>
            <field name="arch" type="xml">
                <list string="Trabajos de recálculo de costos" create="false">
                    <field name="create_date"/>
                    <field name="name"/>
                    <field name="state"/>
                    <field name="processed_templates"/>
                    <field name="total_templates"/>
                    <field name="updated_templates"/>
                    <field name="skipped_templates"/>
                    <field name="last_error"/>
                </list>
            </field>
        </record>

        <record id="view_sync_syscom_cost_job_form" model="ir.ui.view">
            <field name="name">sync.syscom.cost.job.form</field>
            <field name="model">sync.syscom.cost.job</field>
            <field name="arch" type="xml">
                <form string="Trabajo de recálculo de costos">
                    <sheet>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="state" readonly="1"/>
                            <field name="started_at" readonly="1"/>
                            <field name="finished_at" readonly="1"/>
                        </group>
                        <group string="Progreso">
                            <field name="template_offset" readonly="1"/>
                            <field name="processed_templates" readonly="1"/>
                            <field name="total_templates" readonly="1"/>
                            <field name="updated_templates" readonly="1"/>
                            <field name="skipped_templates" readonly="1"/>
                        </group>
                        <group string="Errores">
                            <field name="last_error" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sync_syscom_cost_job_search" model="ir.ui.view">
            <field name="name">sync.syscom.cost.job.search</field>
            <field name="model">sync.syscom.cost.job</field>
            <field name="arch" type="xml">
                <search string="Buscar trabajos de recálculo de costos">
                    <field name="name"/>
                    <filter name="pending" string="Pendientes" domain="[('state', '=', 'pending')]"/>
                    <filter name="running" string="Procesando" domain="[('state', '=', 'running')]"/>
                    <filter name="done" string="Terminados" domain="[('state', '=', 'done')]"/>
                    <filter name="error" string="Con error" domain="[('state', '=', 'error')]"/>
                </search>
            </field>
        </record>

        <record id="action_sync_syscom_cost_job" model="ir.actions.act_window">
            <field name="name">Trabajos recálculo de costos</field>
            <field name="res_model">sync.syscom.cost.job</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
