<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_template_form_sync_syscom" model="ir.ui.view">
            <field name="name">product.template.form.sync.syscom</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="SYSCOM" groups="sync_syscom.group_sync_syscom_manager">
                        <group>
                            <field name="syscom_is_product" readonly="1"/>
                            <field name="syscom_product_id" readonly="1"/>
                            <field name="brand_id"/>
                            <field name="syscom_warranty"/>
                            <field name="weight"/>
                            <field name="syscom_height_cm"/>
                            <field name="syscom_length_cm"/>
                            <field name="syscom_width_cm"/>
                        </group>
                        <group string="Características">
                            <field name="syscom_features_json"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
