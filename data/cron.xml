<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_sync_syscom_brands_full" model="ir.cron">
            <field name="name">Sync Syscom: marcas (background)</field>
            <field name="model_id" ref="model_sync_syscom_brand"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_all_brands_batch()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">False</field>
        </record>
        <record id="cron_sync_syscom_categories" model="ir.cron">
            <field name="name">Sync Syscom: categorías (background)</field>
            <field name="model_id" ref="model_sync_syscom_category"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_categories()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">False</field>
        </record>
        <record id="cron_sync_syscom_brand_products" model="ir.cron">
            <field name="name">Sync Syscom: productos de marcas (background)</field>
            <field name="model_id" ref="model_sync_syscom_brand"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_brand_products_batch()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">False</field>
        </record>

        <record id="cron_sync_syscom_sync_jobs" model="ir.cron">
            <field name="name">Sync Syscom: catálogo (jobs)</field>
            <field name="model_id" ref="model_sync_syscom_sync_job"/>
            <field name="state">code</field>
            <field name="code">model.cron_process_sync_jobs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <record id="cron_sync_syscom_cost_jobs" model="ir.cron">
            <field name="name">Sync Syscom: recálculo de costos</field>
            <field name="model_id" ref="model_sync_syscom_cost_job"/>
            <field name="state">code</field>
            <field name="code">model.cron_process_cost_jobs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <record id="cron_sync_syscom_exchange_rate" model="ir.cron">
            <field name="name">Sync Syscom: tipo de cambio semanal</field>
            <field name="model_id" ref="model_sync_syscom_product"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_exchange_rate()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <record id="cron_sync_syscom_stock_daily" model="ir.cron">
            <field name="name">Sync Syscom: stock/precios (background)</field>
            <field name="model_id" ref="model_sync_syscom_product"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_stock_selected()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Background publisher for selected products (runs frequently, no-op if nothing pending) -->
        <record id="cron_sync_syscom_publish_selected" model="ir.cron">
            <field name="name">Sync Syscom: publicar seleccionados (background)</field>
            <field name="model_id" ref="model_sync_syscom_product"/>
            <field name="state">code</field>
            <field name="code">model.cron_publish_selected_products()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <record id="cron_sync_syscom_publish_category_jobs" model="ir.cron">
            <field name="name">Sync Syscom: publicar categorías (background)</field>
            <field name="model_id" ref="model_sync_syscom_publish_job"/>
            <field name="state">code</field>
            <field name="code">model.cron_process_publish_jobs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
